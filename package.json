{
  "name": "review-council",
  "version": "1.0.0",
  "description": "Review Council — multi-model AI code review CLI",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "rcl": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allocator-one/rcl.git"
  },
  "keywords": [
    "code-review",
    "ai",
    "cli",
    "anthropic",
    "openai",
    "gemini",
    "llm",
    "multi-model",
    "consensus",
    "static-analysis"
  ],
  "author": "Michael Ströck",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/allocator-one/rcl/issues"
  },
  "homepage": "https://github.com/allocator-one/rcl#readme",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/genai": "^1.48.0",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
